<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.distributed.inventory.mapper.ProductMapper">

    <resultMap id="BaseResultMap" type="com.distributed.inventory.entity.Product">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="name" property="name" jdbcType="VARCHAR"/>
        <result column="description" property="description" jdbcType="VARCHAR"/>
        <result column="price" property="price" jdbcType="DECIMAL"/>
        <result column="stock" property="stock" jdbcType="INTEGER"/>
        <result column="image_url" property="imageUrl" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, name, description, price, stock, image_url, create_time, update_time
    </sql>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM product
        WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM product
        ORDER BY id ASC
    </select>

    <insert id="insert" parameterType="com.distributed.inventory.entity.Product" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (name, description, price, stock, image_url, create_time, update_time)
        VALUES (#{name}, #{description}, #{price}, #{stock}, #{imageUrl}, NOW(), NOW())
    </insert>

    <update id="updateStock">
        UPDATE product SET stock = #{stock}, update_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>
