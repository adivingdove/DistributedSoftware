<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.distributed.inventory.mapper.TccTransactionMapper">

    <resultMap id="BaseResultMap" type="com.distributed.inventory.entity.TccTransaction">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="tx_id" property="txId" jdbcType="VARCHAR"/>
        <result column="order_id" property="orderId" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="status" property="status" jdbcType="VARCHAR"/>
        <result column="tx_type" property="txType" jdbcType="VARCHAR"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="com.distributed.inventory.entity.TccTransaction">
        INSERT INTO tcc_transaction (tx_id, order_id, user_id, status, tx_type, create_time, update_time)
        VALUES (#{txId}, #{orderId}, #{userId}, #{status}, #{txType}, NOW(), NOW())
    </insert>

    <update id="updateStatus">
        UPDATE tcc_transaction SET status = #{status}, update_time = NOW()
        WHERE tx_id = #{txId}
    </update>

    <select id="selectByTxId" resultMap="BaseResultMap">
        SELECT * FROM tcc_transaction WHERE tx_id = #{txId}
    </select>

    <select id="selectHangingTransactions" resultMap="BaseResultMap">
        SELECT * FROM tcc_transaction
        WHERE status = 'TRYING'
          AND create_time &lt; DATE_SUB(NOW(), INTERVAL #{timeoutMinutes} MINUTE)
        ORDER BY create_time ASC
        LIMIT 50
    </select>

</mapper>
