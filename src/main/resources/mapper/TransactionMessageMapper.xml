<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.distributed.inventory.mapper.TransactionMessageMapper">

    <resultMap id="BaseResultMap" type="com.distributed.inventory.entity.TransactionMessage">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="message_id" property="messageId" jdbcType="VARCHAR"/>
        <result column="topic" property="topic" jdbcType="VARCHAR"/>
        <result column="message_body" property="messageBody" jdbcType="VARCHAR"/>
        <result column="status" property="status" jdbcType="TINYINT"/>
        <result column="retry_count" property="retryCount" jdbcType="INTEGER"/>
        <result column="max_retry" property="maxRetry" jdbcType="INTEGER"/>
        <result column="create_time" property="createTime" jdbcType="TIMESTAMP"/>
        <result column="update_time" property="updateTime" jdbcType="TIMESTAMP"/>
    </resultMap>

    <insert id="insert" parameterType="com.distributed.inventory.entity.TransactionMessage">
        INSERT INTO transaction_message (message_id, topic, message_body, status, retry_count, max_retry, create_time, update_time)
        VALUES (#{messageId}, #{topic}, #{messageBody}, #{status}, #{retryCount}, #{maxRetry}, NOW(), NOW())
    </insert>

    <update id="updateStatus">
        UPDATE transaction_message SET status = #{status}, update_time = NOW()
        WHERE message_id = #{messageId}
    </update>

    <update id="incrementRetryCount">
        UPDATE transaction_message SET retry_count = retry_count + 1, update_time = NOW()
        WHERE message_id = #{messageId}
    </update>

    <select id="selectPendingMessages" resultMap="BaseResultMap">
        SELECT * FROM transaction_message
        WHERE status IN (0, 3) AND retry_count &lt; #{maxRetry}
        ORDER BY create_time ASC
        LIMIT 100
    </select>

    <select id="selectByMessageId" resultMap="BaseResultMap">
        SELECT * FROM transaction_message WHERE message_id = #{messageId}
    </select>

</mapper>
